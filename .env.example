# Formation Exceptionelle — environment configuration
# Copy this file to `.env.local` and fill in real values.

# Base URL of the backend API.
# While this is EMPTY, the app runs fully in frontend mock mode:
#   - video uploads are simulated in the browser (no real storage)
#   - uploaded videos only play during the current session
# Set it to your API origin to switch video uploads to the real backend
# (see src/services/videoService.js -> realUpload).
VITE_API_BASE_URL=

# Optional: which video platform the backend uses behind the scenes
# (informational only — the frontend just calls VITE_API_BASE_URL).
# Examples: mux | cloudflare-stream | s3
VITE_VIDEO_PROVIDER=
